# ============================================
# DABBA NATION - Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── MongoDB ────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dabba-nation?retryWrites=true&w=majority

# ─── JWT ────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_change_this
JWT_EXPIRES_IN=7d

# ─── Server ─────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Razorpay ───────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# ─── Stripe (optional) ──────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx

# ─── Twilio SMS (optional) ──────────────────
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE=+1234567890

# ─── AWS S3 (Image Uploads) ─────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=dabba-nation-uploads

# ─── File Uploads ───────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ─── CORS ───────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Admin Seed ─────────────────────────────
ADMIN_EMAIL=admin@dabbanation.com
ADMIN_PASSWORD=admin123456
